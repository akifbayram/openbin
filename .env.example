# ──────────────────────────────────────────────
# OpenBin — Environment Variable Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and uncomment the vars you need.
# All values shown are the defaults.

# ── Docker ──────────────────────────────────
# HOST_PORT=1453                    # Externally-exposed port (maps to container :1453)

# ── Server ──────────────────────────────────
# PORT=1453                         # Internal server port (rarely needs changing)

# ── Authentication ────────────────────────────
# JWT_SECRET=                        # Auto-generated if unset
# JWT_EXPIRES_IN=7d                  # Legacy token lifetime (API key compat)
# ACCESS_TOKEN_EXPIRES_IN=15m        # Short-lived access token (httpOnly cookie)
# REFRESH_TOKEN_MAX_DAYS=7           # Refresh token lifetime in days (1–90)
# COOKIE_SECURE=                     # Force Secure flag on cookies (auto: true in production)
# BCRYPT_ROUNDS=12                   # 10–31 (higher = slower but more secure)
# REGISTRATION_MODE=open              # open | invite (require location invite code) | closed (no sign-ups)

# ── Storage ───────────────────────────────────
# STORAGE_BACKEND=local               # local (default) | s3
# S3_BUCKET=                           # Required when STORAGE_BACKEND=s3
# S3_REGION=us-east-1                  # AWS region (default: us-east-1)
# S3_ENDPOINT=                         # Custom endpoint for MinIO / Cloudflare R2 / etc.
# S3_ACCESS_KEY_ID=                    # Required when STORAGE_BACKEND=s3
# S3_SECRET_ACCESS_KEY=                # Required when STORAGE_BACKEND=s3
# S3_FORCE_PATH_STYLE=false            # Set true for MinIO and other path-style S3-compatible services

# ── Upload Limits ─────────────────────────────
# MAX_PHOTO_SIZE_MB=5                # 1–50 MB per photo upload
# MAX_AVATAR_SIZE_MB=2               # 1–10 MB per avatar upload
# MAX_PHOTOS_PER_BIN=1               # Max photos per bin (1–100)
# UPLOAD_QUOTA_DEMO_MB=5              # Per-user upload quota in demo mode (MB)
# UPLOAD_QUOTA_GLOBAL_DEMO_MB=50     # Global upload quota in demo mode (MB)

# ── Malware Scanning (ClamAV) ────────────────
# Optional — only needed for cloud/multi-user deployments.
# When CLAMAV_HOST is unset, scanning is disabled and uploads work as before.
# CLAMAV_HOST=                        # ClamAV daemon hostname (e.g. clamav in Docker Compose)
# CLAMAV_PORT=3310                    # ClamAV daemon port
# CLAMAV_TIMEOUT=30000                # Scan timeout in milliseconds

# ── AI Provider (server-wide fallback) ────────
# When set, all users get AI features without configuring their own keys.
# Users can still override with their own settings.
# AI_PROVIDER=                       # openai | anthropic | gemini | openai-compatible
# AI_API_KEY=
# AI_MODEL=                          # e.g. gpt-5-mini, claude-sonnet-4-6, gemini-3-flash-preview
# AI_ENDPOINT_URL=                   # Only for openai-compatible (e.g. http://localhost:11434/v1)

# ── AI Encryption ─────────────────────────────
# Encrypts user AI API keys at rest (AES-256-GCM).
# Generate with: openssl rand -base64 32
# AI_ENCRYPTION_KEY=

# ── Email (Resend — https://resend.com) ────────
# EMAIL_ENABLED=false                # Set true to enable transactional emails
# RESEND_API_KEY=re_xxxxx            # API key from Resend dashboard
# EMAIL_FROM=OpenBin <noreply@openbin.app>

# ── Backups ───────────────────────────────────
# BACKUP_ENABLED=false
# BACKUP_INTERVAL=daily              # hourly | daily | weekly | cron expression
# BACKUP_RETENTION=7                 # Number of backups to keep (1–365)
# BACKUP_WEBHOOK_URL=                # POST on failure (JSON: { event, error, timestamp })

# ── Rate Limiting ─────────────────────────────
# DISABLE_RATE_LIMIT=false           # Set to true to disable all rate limiters
# AI_RATE_LIMIT=30                   # Max AI requests per hour per user (JWT auth)
# AI_RATE_LIMIT_API_KEY=1000         # Max AI requests per hour per API key

# ── Demo ─────────────────────────────────────
# DEMO_MODE=false                    # Auto-login visitors with pre-populated sample data; resets on restart
# DEMO_USERNAMES=                    # Comma-separated usernames blocked from reading/writing AI API keys (e.g. demo,guest)
# AI_MOCK=false                      # Return fake AI responses (no API key needed); for testing the photo flow
# DEMO_AI_RATE_LIMIT=10              # Max AI tokens per hour for demo users
# DEMO_AI_MAX_PHOTOS_PER_REQUEST=3   # Max photos per AI request for demo users
# DEMO_AI_DAILY_BUDGET=100           # Max AI tokens per day for demo users

# ── QR Code Payload ──────────────────────────────
# QR_PAYLOAD_MODE=app                # app (openbin://bin/ID, in-app only) | url (BASE_URL/bin/ID, works with any camera)
# BASE_URL=                          # Required when QR_PAYLOAD_MODE=url (e.g. https://inventory.example.com)

# ── Logging ───────────────────────────────────
# LOG_LEVEL=info                     # debug | info | warn | error

# ── Advanced ──────────────────────────────────
# CORS_ORIGIN=http://localhost:5173  # Only needed for non-Docker dev setups
# TRUST_PROXY=false                  # Set to true when behind a reverse proxy (nginx, Caddy, etc.)
# FRAME_ANCESTORS=                    # Space-separated origins allowed to embed in iframe (e.g. https://openbin.app)

# ── Cloud Tier ──────────────────────────────────
# SELF_HOSTED=true                   # Master switch: true = all features unlocked (default)
#                                    # Set to false for cloud deployment with plan enforcement
# MANAGER_URL=                       # External subscription manager URL (cloud only)
# SUBSCRIPTION_JWT_SECRET=           # Shared secret for subscription callback JWT verification
# SUBSCRIPTION_WEBHOOK_SECRET=       # Optional HMAC secret for webhook signatures
